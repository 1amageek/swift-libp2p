# syntax=docker/dockerfile:1.7
# Dockerfile for rust-libp2p TCP + Noise test node
#
# This creates a rust-libp2p node that listens on TCP with Noise security
# and supports Identify and Ping protocols.

FROM rust:1.83-alpine AS builder

WORKDIR /app

# Install build dependencies
RUN apk add --no-cache musl-dev

# Install nightly Rust for edition2024 support
RUN rustup toolchain install nightly && rustup default nightly

# Create a new Rust project
RUN cargo init --name rust-libp2p-tcp-test

# Add dependencies to Cargo.toml
COPY Dockerfiles/generated/Dockerfile.tcp.rust/Cargo.toml Cargo.toml
# Create the test server with TCP + Noise
COPY Dockerfiles/generated/Dockerfile.tcp.rust/src/main.rs src/main.rs
# Build the application
RUN cargo build --release

# Final image
FROM alpine:3.19

COPY --from=builder /app/target/release/rust-libp2p-tcp-test /usr/local/bin/rust-libp2p-tcp-test

EXPOSE 4001/tcp

ENTRYPOINT ["/usr/local/bin/rust-libp2p-tcp-test"]
